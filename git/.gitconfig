[pager]
	branch = false
[core]
	excludesfile = ~/.gitignore_global
	ignorecase = false
	autocrlf = input
[include]
	path = ~/.gitconfig.local
[pull]
	rebase = true
[init]
	defaultBranch = main
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[commit]
	gpgsign = true
[tag]
	gpgsign = true
