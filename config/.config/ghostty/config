macos-titlebar-style = hidden

quick-terminal-position = top
quick-terminal-size = 75%
keybind = global:ctrl+enter=toggle_quick_terminal

keybind = alt+u=scroll_page_up
keybind = alt+d=scroll_page_down

keybind = alt+g=scroll_to_top
keybind = alt+shift+g=scroll_to_bottom

cursor-style = block
cursor-style-blink = true
cursor-color = #ffb473
shell-integration-features = no-cursor

font-family = JetBrainsMono Nerd Font Mono
font-size = 15

theme = Custom-iTerm

background-opacity = 0.75
background-blur-radius = 20
background-image = backgrounds/background.png

selection-background = #454d96
foreground = #b8b8b8
background = #050505
selection-background = #353b72
# foreground = #c7c7c7
# background = #000000

term = xterm-256color
macos-option-as-alt = true

window-padding-x = 8
window-padding-y = 6
adjust-cell-height = 5%
